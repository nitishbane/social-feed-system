# Base API URL
LOAD_TARGET=http://127.0.0.1:3000

# Scenario: feed, mixed, write
LOAD_SCENARIO=mixed

# Profile: smoke, constant, ramp
LOAD_PROFILE=constant

# Used by smoke and constant profiles
LOAD_VUS=50
LOAD_DURATION=2m

# Seeded data ranges
LOAD_USER_COUNT=1000
LOAD_POST_COUNT=20000

# Feed and pacing
LOAD_FEED_LIMIT=20
LOAD_THINK_TIME=0.2
